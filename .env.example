# ── Environment Variables ──────────────────────────────────────────────────────
# Copy this file to .env and fill in your API key(s).
# The app will use Gemini first, then OpenAI, then fall back to raw data.
# ──────────────────────────────────────────────────────────────────────────────

# Google Gemini API key (preferred)
# Get one at: console.cloud.google.com → AI Studio → API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API key (fallback)
# Get one at: platform.openai.com → API Keys
OPENAI_API_KEY=your_openai_api_key_here

# Server settings (optional — defaults shown)
# DEBUG=true
# HOST=0.0.0.0
# PORT=5000
